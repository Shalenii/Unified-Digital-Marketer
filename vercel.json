{
    "version": 2,
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "* * * * *"
        }
    ],
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/whatsapp/:path*",
            "destination": "https://unified-digital-marketer-production.up.railway.app/api/whatsapp/:path*"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/client/$1"
        }
    ]
}